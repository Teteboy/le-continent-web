# Le Continent Backend - Environment Variables
# Copy this file to .env and fill in your values

# Server Configuration
PORT=3000
HOST=0.0.0.0

# Your production domain (required for payment callbacks)
APP_URL=https://your-domain.com
CALLBACK_URL=https://your-api-domain.com/api/payment/webhook

# Supabase Configuration
# Use the SERVICE ROLE key here (server-side only — never expose to frontend!)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-service-role-key

# Redis Configuration (optional but recommended for caching performance)
# Get a free Redis instance from https://redis.com/try-free/ or https://upstash.com
REDIS_URL=redis://default:password@your-redis-host:port

# Cache TTL values (in seconds)
CACHE_TTL=300              # General cache: 5 minutes
AUTH_CACHE_TTL=3600        # Auth/profile cache: 1 hour
CONTENT_CACHE_TTL=3600     # Content cache: 1 hour
VILLAGE_CACHE_TTL=3600     # Village cache: 1 hour

# CamPay Payment Configuration
# Get credentials from https://campay.net/
# Use https://demo.campay.net for testing, https://www.campay.net for production
CAMPAY_BASE_URL=https://www.campay.net
CAMPAY_USERNAME=your-campay-username
CAMPAY_PASSWORD=your-campay-password
CAMPAY_PERMANENT_TOKEN=your-campay-permanent-token
CAMPAY_WEBHOOK_KEY=your-campay-webhook-key

# Payment Configuration
PAYMENT_TIMEOUT=180000

# Rate Limiting
RATE_LIMIT_MAX=1000
RATE_LIMIT_WINDOW=900000
